{
  "name": "its-ischia-transfer-service",
  "version": "1.0.0",
  "description": "A modern single-page website for I.T.S. Ischia Transfer Service S.r.l.",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss build styles/tailwind.css -o styles/generated.css",
    "build:js": "esbuild scripts/main.js --minify --outfile=scripts/main.min.js",
    "build": "npm run build:css && npm run build:js",
    "watch": "tailwindcss build styles/tailwind.css -o styles/generated.css --watch",
    "start": "node server.js",
    "test": "node tools/smoke-test.js",
    "test:pages": "node tools/browserless-smoke.js",
    "test:playwright": "node tools/playwright-smoke.js",
    "lint": "eslint . --ext .js",
    "lint:js": "eslint . --ext .js"
  },
  "dependencies": {
    "nodemailer": "^8.0.3",
    "tailwindcss": "^2.2.19"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "axe-core": "^4.11.1",
    "esbuild": "^0.25.12",
    "eslint": "^8.57.1",
    "playwright": "^1.58.2"
  },
  "author": "I.T.S. Ischia Transfer Service S.r.l.",
  "license": "MIT"
}
